# Python — root-anchored where they exist as Python conventions only.
# Unanchored `lib/` and `bin/` would shadow `loom/src/lib/` (SvelteKit
# server modules) and silently drop the entire Loom server tree from
# git history. They are anchored to repo root here.
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
/bin/
/var/
sdist/
develop-eggs/
.installed.cfg
/lib/
/lib64/
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# uv / virtualenv
.venv/
venv/
env/
ENV/
.uv/

# Environment and secrets — NEVER commit
# Anchored to repo-root or to specific extensions; an unanchored
# `secrets.*` would silently exclude `loom/src/lib/server/secrets.ts`
# (the source code that manages the encrypted vault).
.env
.env.*
*.pem
*.key
/secrets/
secrets.env
secrets.env.*
secrets.json
secrets.yaml
secrets.yml
*.secret
*.tfvars
credentials.json

# Model weights (large; download per WEAVER-SETUP.md, do not commit)
models/
*.bin
*.safetensors
*.gguf
*.pt
*.ckpt

# Vector and database state
qdrant_storage/
postgres_data/
*.sqlite
*.sqlite3
*.db

# Audit logs (operational state, not source) — root-anchored so they
# do not shadow `loom/src/routes/admin/audit/` (the source for the
# audit-log admin page).
/audit/
*.log
/logs/

# Local provisioning artifacts
provisioning/local/
*.local.yaml
*.local.yml

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
._*

# OS
Thumbs.db
ehthumbs.db
Desktop.ini

# Direnv
.envrc

# Jupyter
.ipynb_checkpoints/
*.ipynb

# MCP / Claude Code session artifacts
.claude/
*.session.json

# Backups
*.bak
*.backup
backups/

# Node / pnpm / SvelteKit (Loom + SDK)
node_modules/
.pnpm-store/
build/
dist/
.svelte-kit/
*.tsbuildinfo
.turbo/

# Test / coverage
coverage/
playwright-report/
test-results/

# Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
