{
  "name": "@webspinner-foundation/sdk",
  "version": "0.0.0",
  "description": "Foundational types for Warp: VaultURI, AuditEvent, SpinnerManifest, WarpThreadManifest, integrity primitives. Every Spinner imports from here.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://webspinner.ai/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webspinner-org/warp.git",
    "directory": "sdk"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "24.12.3",
    "vitest": "4.1.0"
  }
}
