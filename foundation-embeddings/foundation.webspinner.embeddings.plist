<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Foundation embeddings service — BGE-M3 on Kepler.

  Serves the embedding endpoint on 127.0.0.1:8101. First leg of the
  v2 propose retrieval chain. Source lives at ~/warp/foundation-embeddings/
  (synced from the Spindle repo). Python venv at ~/foundation-embeddings-venv/.

  Per loom-design.md §5.3.1. Sub-100ms per query on Apple Silicon
  with MPS backend (PyTorch).
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>foundation.webspinner.embeddings</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/johndavidmarx/foundation-embeddings-venv/bin/uvicorn</string>
    <string>main:app</string>
    <string>--host</string>
    <string>127.0.0.1</string>
    <string>--port</string>
    <string>8101</string>
    <string>--log-level</string>
    <string>info</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/johndavidmarx/warp/foundation-embeddings</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>WARP_EMBEDDINGS_EAGER</key>
    <string>1</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
    <key>Crashed</key>
    <true/>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/johndavidmarx/Library/Logs/foundation-embeddings/stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/johndavidmarx/Library/Logs/foundation-embeddings/stderr.log</string>

  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
