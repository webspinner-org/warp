# Strict peer/engine resolution — surface mismatches loudly at install time.
strict-peer-dependencies=true
engine-strict=true

# Enforce packageManager field — refuse to run under a different pnpm version.
package-manager-strict=true

# Auto-install peer deps (default in pnpm 9+, explicit for clarity).
auto-install-peers=true

# Isolated workspace layout — pnpm's strict default; no phantom deps across packages.
node-linker=isolated
