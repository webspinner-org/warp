#!/usr/bin/env bash
#
# tools/hub-bootstrap-projects — one-shot backfill of work-in-process
# Webbase projects into the hub.
#
# Reads every row in the demo Cell's wp_database_applications (the
# patron's *source*, built but not necessarily published) and writes
# each as a project directory under
# $HUB_STORAGE_DIR/try-webspinner-projects/webbase-apps/<sessionId>/.
# Subsequent builds auto-sync via the demo Loom's side-write in
# createApp; this tool just gets the existing rows visible the first
# time.
#
# Wipes any prior webbase-apps/ contents (publish-artifact bootstrap
# left stale data behind — projects use sessionId keys, packages
# used shortCodes; clean slate is safest).
#
# Run on Kepler.

set -euo pipefail
export PATH="/opt/homebrew/bin:/usr/local/bin:${PATH:-/usr/bin:/bin}"

HUB_STORAGE_DIR="${HUB_STORAGE_DIR:-$HOME/webspinner-hub/storage}"
DEMO_PB="${WARP_PB_URL:-http://127.0.0.1:8091}"
RESUME_BASE="${WARP_TRY_BASE:-https://try.webspinner.ai}"

PLIST_INFO=$(launchctl print "gui/$(id -u)/foundation.webspinner.loom-demo" 2>/dev/null || true)
DEMO_EMAIL=$(echo "$PLIST_INFO" | sed -n 's/.*WARP_PB_EMAIL *=> *\(.*\) *$/\1/p' | tr -d ' ')
DEMO_PASS=$(echo "$PLIST_INFO" | sed -n 's/.*WARP_PB_PASSWORD *=> *\(.*\) *$/\1/p' | tr -d ' ')

if [ -z "$DEMO_EMAIL" ] || [ -z "$DEMO_PASS" ]; then
  echo "[bootstrap] couldn't read demo Loom PB creds from launchd plist" >&2
  exit 1
fi

WB_DIR="$HUB_STORAGE_DIR/try-webspinner-projects/webbase-apps"
echo "[bootstrap] hub storage = $HUB_STORAGE_DIR"
echo "[bootstrap] demo PB     = $DEMO_PB"
echo "[bootstrap] wiping prior contents of $WB_DIR"
rm -rf "$WB_DIR"
mkdir -p "$WB_DIR"

AUTH_JSON=$(curl -sS -X POST "$DEMO_PB/api/collections/_superusers/auth-with-password" \
  -H 'Content-Type: application/json' \
  --data-binary @<(printf '{"identity":"%s","password":"%s"}' "$DEMO_EMAIL" "$DEMO_PASS"))
TOKEN=$(echo "$AUTH_JSON" | python3 -c 'import sys,json;print(json.load(sys.stdin)["token"])')
[ -z "$TOKEN" ] && { echo "[bootstrap] auth failed: $AUTH_JSON" >&2; exit 1; }

ROWS=$(curl -sS -H "Authorization: $TOKEN" \
  "$DEMO_PB/api/collections/wp_database_applications/records?perPage=500&sort=-created")

export HUB_STORAGE_DIR RESUME_BASE
python3 - <<PY
import json, os, pathlib
rows = json.loads('''$ROWS''').get("items", [])
root = pathlib.Path(os.environ["HUB_STORAGE_DIR"]) / "try-webspinner-projects" / "webbase-apps"
root.mkdir(parents=True, exist_ok=True)
resume_base = os.environ.get("RESUME_BASE", "https://try.webspinner.ai")

written = 0
for r in rows:
  sid = r.get("session_id")
  if not sid:
    continue
  sd = (r.get("schema_draft") or {}).get("screensDraft") or {}
  branding = (r.get("schema_draft") or {}).get("branding")
  entities = r.get("entities") or []
  app_name = sd.get("appName") or (f"Your {r.get('domain','')}".strip() or "(unnamed Webbase)")
  built_at = r.get("built_at") or ""
  created_at = r.get("created") or built_at
  updated_at = r.get("updated") or created_at
  meta = {
    "sessionId": sid,
    "appName": app_name,
    "domain": r.get("domain") or "",
    "patronSentence": r.get("patron_sentence") or "",
    "status": "built" if built_at else "ready",
    "appId": r.get("app_id") or "",
    "entityCount": len(entities),
    "screenCount": len(sd.get("screens") or []),
    "createdAt": created_at,
    "updatedAt": updated_at,
    "builtAt": built_at,
    "resumeUrl": f"{resume_base}/?resume={sid}",
  }
  source = {
    "screensDraft": sd,
    "branding": branding,
    "entities": entities,
  }
  pkg = root / sid
  pkg.mkdir(parents=True, exist_ok=True)
  (pkg / "project.json").write_text(json.dumps(source, indent=2))
  (pkg / "meta.json").write_text(json.dumps(meta, indent=2))
  written += 1
  print(f"  wrote {sid} — {app_name} ({meta['status']}, {meta['entityCount']} entities)")

print(f"[bootstrap] wrote {written} project(s) into {root}")
PY
