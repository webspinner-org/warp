{
  "appName": "Prayer List",
  "domain": "personal prayer practice",
  "screens": [
    {
      "id": "form-request",
      "kind": "form",
      "name": "Add Request",
      "describes": "Add a prayer request.",
      "parentEntity": "request",
      "layout": {
        "sections": [
          {
            "title": "Request",
            "fields": [
              {
                "id": "subject",
                "label": "Subject",
                "kind": "text",
                "required": true
              },
              {
                "id": "description",
                "label": "Description",
                "kind": "long-text"
              },
              {
                "id": "added_at",
                "label": "Added At",
                "kind": "date",
                "required": true
              },
              {
                "id": "category",
                "label": "Category",
                "kind": "choice",
                "options": [
                  "family",
                  "friend",
                  "church",
                  "community",
                  "world",
                  "personal",
                  "thanksgiving"
                ]
              },
              {
                "id": "priority",
                "label": "Priority",
                "kind": "choice",
                "options": ["ongoing", "urgent", "lift-up"]
              },
              {
                "id": "answered_at",
                "label": "Answered At",
                "kind": "date"
              },
              {
                "id": "answer_notes",
                "label": "Answer Notes",
                "kind": "long-text"
              }
            ]
          }
        ]
      }
    },
    {
      "id": "list-request",
      "kind": "list",
      "name": "All requests",
      "describes": "Browse all requests.",
      "parentEntity": "request",
      "layout": {
        "columns": [
          {
            "fieldId": "subject"
          },
          {
            "fieldId": "category"
          },
          {
            "fieldId": "added_at"
          },
          {
            "fieldId": "priority"
          }
        ],
        "defaultSort": {
          "field": "added_at",
          "direction": "desc"
        }
      }
    },
    {
      "id": "detail-request",
      "kind": "detail",
      "name": "Request details",
      "describes": "View one request.",
      "parentEntity": "request",
      "layout": {
        "showFields": [
          "subject",
          "description",
          "added_at",
          "category",
          "priority",
          "answered_at",
          "answer_notes"
        ]
      }
    }
  ],
  "navigation": [
    {
      "label": "Requests",
      "primary": true,
      "screens": ["form-request", "list-request"]
    }
  ],
  "branding": {
    "options": [
      {
        "id": "paper",
        "name": "Paper",
        "mood": "warm",
        "palette": {
          "bg": "#f8f5ed",
          "surface": "#ffffff",
          "surfaceAlt": "#f0e9d8",
          "border": "#d4c8b0",
          "text": "#1f1a14",
          "textMuted": "#6a5d4a",
          "accent": "#8a6a3a",
          "accentSoft": "#b8965f",
          "gold": "#b8965f"
        }
      }
    ],
    "selectedPaletteId": "paper"
  }
}
