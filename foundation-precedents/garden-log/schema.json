{
  "appName": "Garden Log",
  "domain": "garden tracking",
  "screens": [
    {
      "id": "form-plant",
      "kind": "form",
      "name": "Add Plant",
      "describes": "Record a plant.",
      "parentEntity": "plant",
      "layout": {
        "sections": [
          {
            "title": "Plant",
            "fields": [
              {
                "id": "name",
                "label": "Name",
                "kind": "text",
                "required": true
              },
              {
                "id": "variety",
                "label": "Variety",
                "kind": "text"
              },
              {
                "id": "planted_at",
                "label": "Planted At",
                "kind": "date",
                "required": true
              },
              {
                "id": "location",
                "label": "Location",
                "kind": "choice",
                "options": [
                  "front-bed",
                  "back-bed",
                  "side-bed",
                  "container",
                  "raised-bed",
                  "greenhouse"
                ]
              },
              {
                "id": "sun",
                "label": "Sun",
                "kind": "choice",
                "options": ["full-sun", "part-sun", "shade"]
              },
              {
                "id": "notes",
                "label": "Notes",
                "kind": "long-text"
              },
              {
                "id": "removed",
                "label": "Removed",
                "kind": "yes-no"
              }
            ]
          }
        ]
      }
    },
    {
      "id": "list-plant",
      "kind": "list",
      "name": "All plants",
      "describes": "Browse all plants.",
      "parentEntity": "plant",
      "layout": {
        "columns": [
          {
            "fieldId": "name"
          },
          {
            "fieldId": "variety"
          },
          {
            "fieldId": "planted_at"
          },
          {
            "fieldId": "location"
          }
        ]
      }
    },
    {
      "id": "detail-plant",
      "kind": "detail",
      "name": "Plant details",
      "describes": "View one plant.",
      "parentEntity": "plant",
      "layout": {
        "showFields": ["name", "variety", "planted_at", "location", "sun", "notes", "removed"]
      }
    },
