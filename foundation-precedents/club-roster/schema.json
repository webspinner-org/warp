{
  "appName": "Club Roster",
  "domain": "small-club membership",
  "screens": [
    {
      "id": "form-member",
      "kind": "form",
      "name": "Add Member",
      "describes": "Add a member.",
      "parentEntity": "member",
      "layout": {
        "sections": [
          {
            "title": "Member",
            "fields": [
              {
                "id": "name",
                "label": "Name",
                "kind": "text",
                "required": true
              },
              {
                "id": "email",
                "label": "Email",
                "kind": "text"
              },
              {
                "id": "phone",
                "label": "Phone",
                "kind": "text"
              },
              {
                "id": "joined_at",
                "label": "Joined At",
                "kind": "date"
              },
              {
                "id": "status",
                "label": "Status",
                "kind": "choice",
                "options": ["active", "inactive", "honorary", "lapsed"]
              },
              {
                "id": "notes",
                "label": "Notes",
                "kind": "long-text"
              }
            ]
          }
        ]
      }
    },
    {
      "id": "list-member",
      "kind": "list",
      "name": "All members",
      "describes": "Browse all members.",
      "parentEntity": "member",
      "layout": {
        "columns": [
          {
            "fieldId": "name"
          },
          {
            "fieldId": "email"
          },
          {
            "fieldId": "status"
          },
          {
            "fieldId": "joined_at"
          }
        ]
      }
    },
    {
      "id": "detail-member",
      "kind": "detail",
      "name": "Member details",
      "describes": "View one member.",
      "parentEntity": "member",
      "layout": {
        "showFields": ["name", "email", "phone", "joined_at", "status", "notes"]
      }
    },
    {
      "id": "form-meeting",
      "kind": "form",
      "name": "Add Meeting",
      "describes": "Schedule a meeting.",
      "parentEntity": "meeting",
      "layout": {
        "sections": [
          {
            "title": "Meeting",
            "fields": [
              {
                "id": "held_on",
                "label": "Held On",
                "kind": "date",
                "required": true
              },
              {
                "id": "topic",
                "label": "Topic",
                "kind": "text"
              },
              {
                "id": "location",
                "label": "Location",
                "kind": "text"
              },
              {
                "id": "notes",
                "label": "Notes",
                "kind": "long-text"
              }
            ]
          }
        ]
      }
    },
    {
      "id": "list-meeting",
      "kind": "list",
      "name": "All meetings",
      "describes": "Browse all meetings.",
      "parentEntity": "meeting",
      "layout": {
        "columns": [
          {
            "fieldId": "held_on"
          },
          {
            "fieldId": "topic"
          },
          {
            "fieldId": "location"
          },
          {
            "fieldId": "notes"
          }
        ],
        "defaultSort": {
          "field": "held_on",
          "direction": "desc"
        }
      }
    },
    {
      "id": "detail-meeting",
      "kind": "detail",
      "name": "Meeting details",
      "describes": "View one meeting.",
      "parentEntity": "meeting",
      "layout": {
        "showFields": ["held_on", "topic", "location", "notes"]
      }
    },
    {
      "id": "form-attendance",
      "kind": "form",
      "name": "Add Attendance",
      "describes": "Mark a member present.",
      "parentEntity": "attendance",
      "layout": {
        "sections": [
          {
            "title": "Attendance",
            "fields": [
              {
                "id": "meeting",
                "label": "Meeting",
                "kind": "link-to",
                "required": true,
                "linkTo": "meeting"
              },
              {
                "id": "member",
                "label": "Member",
                "kind": "link-to",
                "required": true,
                "linkTo": "member"
              },
              {
                "id": "role",
                "label": "Role",
                "kind": "choice",
                "options": ["attendee", "speaker", "host", "guest"]
              },
              {
                "id": "notes",
                "label": "Notes",
                "kind": "text"
              }
            ]
          }
        ]
      }
    },
    {
      "id": "list-attendance",
      "kind": "list",
      "name": "All attendances",
      "describes": "Browse all attendances.",
      "parentEntity": "attendance",
      "layout": {
        "columns": [
          {
            "fieldId": "meeting"
          },
          {
            "fieldId": "member"
          },
          {
            "fieldId": "role"
          },
          {
            "fieldId": "notes"
          }
        ]
      }
    },
    {
      "id": "detail-attendance",
      "kind": "detail",
      "name": "Attendance details",
      "describes": "View one attendance.",
      "parentEntity": "attendance",
      "layout": {
        "showFields": ["meeting", "member", "role", "notes"]
      }
    },
    {
      "id": "form-dues_payment",
      "kind": "form",
      "name": "Add Dues payment",
      "describes": "Record a dues payment.",
      "parentEntity": "dues_payment",
      "layout": {
        "sections": [
          {
            "title": "Dues payment",
            "fields": [
              {
                "id": "member",
                "label": "Member",
                "kind": "link-to",
                "required": true,
                "linkTo": "member"
              },
              {
                "id": "paid_at",
                "label": "Paid At",
                "kind": "date",
                "required": true
              },
              {
                "id": "amount",
                "label": "Amount",
                "kind": "money",
                "required": true
              },
              {
                "id": "period",
                "label": "Period",
                "kind": "text",
                "describes": "e.g. '2026', '2026 Q1'"
              },
              {
                "id": "notes",
                "label": "Notes",
                "kind": "text"
              }
            ]
          }
        ]
      }
    },
    {
      "id": "list-dues_payment",
      "kind": "list",
      "name": "All dues_payments",
      "describes": "Browse all dues_payments.",
      "parentEntity": "dues_payment",
      "layout": {
        "columns": [
          {
            "fieldId": "member"
          },
          {
            "fieldId": "paid_at"
          },
          {
            "fieldId": "amount"
          },
          {
            "fieldId": "period"
          }
        ]
      }
    },
    {
      "id": "detail-dues_payment",
      "kind": "detail",
      "name": "Dues payment details",
      "describes": "View one dues_payment.",
      "parentEntity": "dues_payment",
      "layout": {
        "showFields": ["member", "paid_at", "amount", "period", "notes"]
      }
    }
  ],
  "navigation": [
    {
      "label": "Members",
      "primary": true,
      "screens": ["form-member", "list-member"]
    },
    {
      "label": "Meetings",
